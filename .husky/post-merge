#!/bin/sh

echo "🔄 Post-merge hook running..."

# Get list of changed files
changed_files="$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD)"

# Function to check if file changed and run command
check_run() {
  echo "$changed_files" | grep --quiet "$1" && eval "$2"
}

# Check if package.json changed
if echo "$changed_files" | grep --quiet "package.json"; then
  echo "📦 package.json changed, running pnpm install..."
  pnpm install
fi

# Check if pnpm-lock.yaml changed
if echo "$changed_files" | grep --quiet "pnpm-lock.yaml"; then
  echo "🔒 pnpm-lock.yaml changed, running pnpm install..."
  pnpm install
fi

echo "✅ Post-merge hook completed!"

