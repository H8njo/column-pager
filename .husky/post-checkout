#!/bin/sh

# $3 is a flag indicating whether the checkout was a branch checkout (1) or a file checkout (0)
if [ "$3" = "1" ]; then
  echo "🔀 Branch checkout detected..."
  
  # Get list of changed files
  changed_files="$(git diff-tree -r --name-only --no-commit-id $1 $2)"
  
  # Check if package.json or pnpm-lock.yaml changed
  if echo "$changed_files" | grep -q "package.json\|pnpm-lock.yaml"; then
    echo "📦 Dependencies changed, running pnpm install..."
    pnpm install
  fi
  
  echo "✅ Post-checkout hook completed!"
fi

